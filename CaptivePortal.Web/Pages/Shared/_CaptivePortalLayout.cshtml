<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - West Texas A&M University</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    
    <!-- WTAMU Brand Compliant Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Helvetica+Neue:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/captive-portal.css" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    
    <!-- Meta tags for mobile optimization -->
    <meta name="description" content="Connect to West Texas A&M University Wi-Fi network">
    <meta name="keywords" content="WTAMU, Wi-Fi, Internet Access, West Texas A&M University">
    <meta name="author" content="West Texas A&M University">
    
    <!-- Preload critical resources -->
    <link rel="preload" href="/images/wtamu-logo.png" as="image">
</head>
<body>
    <div class="captive-portal-container">
        <!-- Main Content -->
        <main role="main" class="container-fluid">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="portal-footer mt-5">
            <div class="container text-center">
                <div class="row">
                    <div class="col-12">
                        <p class="mb-2">&copy; @DateTime.Now.Year West Texas A&M University</p>
                        <p class="small text-muted">
                            Need help? Contact IT Support: 
                            <a href="mailto:support@wtamu.edu">support@wtamu.edu</a> | 
                            <a href="tel:+18066516000">(806) 651-6000</a>
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>