@page
@model CaptivePortal.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="admin-dashboard">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="page-title">Captive Portal Administration</h1>
            <p class="page-description">Manage your captive portal system and monitor usage statistics.</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary">
                            <i class="bi bi-people-fill text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="card-title mb-1">@Model.TodayConnections</h5>
                            <p class="card-text small text-muted">Connections Today</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success">
                            <i class="bi bi-calendar-week text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="card-title mb-1">@Model.WeekConnections</h5>
                            <p class="card-text small text-muted">This Week</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-info">
                            <i class="bi bi-envelope text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="card-title mb-1">@Model.TotalEmails</h5>
                            <p class="card-text small text-muted">Total Emails</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning">
                            <i class="bi bi-badge-ad text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h5 class="card-title mb-1">@Model.ActiveAds</h5>
                            <p class="card-text small text-muted">Active Ads</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Advertisements" class="btn btn-outline-primary w-100">
                                <i class="bi bi-badge-ad me-2"></i>Manage Ads
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Users" class="btn btn-outline-success w-100">
                                <i class="bi bi-people me-2"></i>User Data
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Settings" class="btn btn-outline-info w-100">
                                <i class="bi bi-gear me-2"></i>Settings
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Reports" class="btn btn-outline-warning w-100">
                                <i class="bi bi-bar-chart me-2"></i>Reports
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Connections</h5>
                </div>
                <div class="card-body">
                    @if (Model.RecentConnections.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Email</th>
                                        <th>Location</th>
                                        <th>Connected At</th>
                                        <th>IP Address</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var connection in Model.RecentConnections)
                                    {
                                        <tr>
                                            <td>@connection.Email</td>
                                            <td>@connection.Location</td>
                                            <td>@connection.ConnectedAt.ToString("MMM dd, HH:mm")</td>
                                            <td><small class="text-muted">@connection.IpAddress</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No recent connections</p>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">System Status</h5>
                </div>
                <div class="card-body">
                    <div class="status-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Portal Status</span>
                            <span class="badge bg-success">Online</span>
                        </div>
                    </div>
                    <div class="status-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Database</span>
                            <span class="badge bg-success">Connected</span>
                        </div>
                    </div>
                    <div class="status-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Last Update</span>
                            <span class="text-muted small">@DateTime.Now.ToString("MMM dd, HH:mm")</span>
                        </div>
                    </div>
                    <hr>
                    <div class="d-grid">
                        <button class="btn btn-sm btn-outline-primary" onclick="location.reload()">
                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>