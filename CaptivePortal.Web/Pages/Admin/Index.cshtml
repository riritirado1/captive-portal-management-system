@page "/Admin"
@model CaptivePortal.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="admin-dashboard">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="page-title">Captive Portal Administration</h1>
            <p class="page-description">Manage your captive portal system and monitor usage statistics.</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-primary">
                            <i class="bi bi-people-fill text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h3 class="card-title mb-1 text-primary">@Model.TodayConnections</h3>
                            <p class="card-text small text-muted mb-0">Connections Today</p>
                            <small class="@(Model.TodayGrowth >= 0 ? "text-success" : "text-danger")">
                                <i class="bi bi-@(Model.TodayGrowth >= 0 ? "arrow-up" : "arrow-down")"></i>
                                @Model.TodayGrowth% from yesterday
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-success">
                            <i class="bi bi-calendar-week text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h3 class="card-title mb-1 text-primary">@Model.WeekConnections</h3>
                            <p class="card-text small text-muted mb-0">This Week</p>
                            <small class="@(Model.WeekGrowth >= 0 ? "text-success" : "text-danger")">
                                <i class="bi bi-@(Model.WeekGrowth >= 0 ? "arrow-up" : "arrow-down")"></i>
                                @Model.WeekGrowth% from last week
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-info">
                            <i class="bi bi-envelope text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h3 class="card-title mb-1 text-primary">@Model.TotalEmails</h3>
                            <p class="card-text small text-muted mb-0">Total Emails</p>
                            <small class="text-info">@Model.UniqueEmails unique</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card stat-card border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon bg-warning">
                            <i class="bi bi-badge-ad text-white"></i>
                        </div>
                        <div class="ms-3">
                            <h3 class="card-title mb-1 text-primary">@Model.ActiveAds</h3>
                            <p class="card-text small text-muted mb-0">Active Ads</p>
                            <small class="text-warning">@Model.TotalAds total created</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Advertisements" class="btn btn-outline-primary w-100">
                                <i class="bi bi-badge-ad me-2"></i>Manage Ads
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Users" class="btn btn-outline-success w-100">
                                <i class="bi bi-people me-2"></i>User Data
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Settings" class="btn btn-outline-info w-100">
                                <i class="bi bi-gear me-2"></i>Settings
                            </a>
                        </div>
                        <div class="col-md-6 col-lg-3 mb-3">
                            <a href="/Admin/Reports" class="btn btn-outline-warning w-100">
                                <i class="bi bi-bar-chart me-2"></i>Reports
                            </a>
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-md-6 mb-2">
                            <a href="/" target="_blank" class="btn btn-outline-secondary w-100">
                                <i class="bi bi-box-arrow-up-right me-2"></i>View Portal
                            </a>
                        </div>
                        <div class="col-md-6 mb-2">
                            <button class="btn btn-outline-info w-100" onclick="location.reload()">
                                <i class="bi bi-arrow-clockwise me-2"></i>Refresh Data
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-activity me-2"></i>Recent Connections</h5>
                </div>
                <div class="card-body">
                    @if (Model.RecentConnections.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Email</th>
                                        <th>Location</th>
                                        <th>Connected At</th>
                                        <th>IP Address</th>
                                        <th>Terms Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var connection in Model.RecentConnections)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar bg-primary rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                        <small class="text-white fw-bold">@connection.Email.Substring(0, 1).ToUpper()</small>
                                                    </div>
                                                    <span>@connection.Email</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="text-muted">@(string.IsNullOrEmpty(connection.Location) ? "Unknown" : connection.Location)</span>
                                            </td>
                                            <td>@connection.ConnectedAt.ToString("MMM dd, HH:mm")</td>
                                            <td><span class="badge bg-light text-dark">@connection.IpAddress</span></td>
                                            <td>
                                                <span class="badge @(connection.AcceptedTerms ? "bg-success" : "bg-warning")">
                                                    @(connection.AcceptedTerms ? "Accepted" : "Pending")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/Admin/Users" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-arrow-right me-1"></i>View All Users (@Model.TotalEmails total)
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                            <h6 class="text-muted mt-2">No recent connections</h6>
                            <p class="text-muted small">User activity will appear here when people connect to the portal</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>System Status</h5>
                </div>
                <div class="card-body">
                    <div class="status-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Portal Status</span>
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Online</span>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Database</span>
                            <span class="badge bg-success"><i class="bi bi-database"></i> Connected</span>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Authentication</span>
                            <span class="badge bg-success"><i class="bi bi-shield-check"></i> Active</span>
                        </div>
                    </div>
                    <div class="status-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Last Update</span>
                            <span class="text-muted small">@DateTime.Now.ToString("MMM dd, HH:mm")</span>
                        </div>
                    </div>
                    <hr>
                    <div class="d-grid gap-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="location.reload()">
                            <i class="bi bi-arrow-clockwise me-2"></i>Refresh Dashboard
                        </button>
                        <a href="/Identity/Account/Logout" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>