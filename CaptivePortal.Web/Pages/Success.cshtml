@page
@model SuccessModel
@{
    ViewData["Title"] = "Connected Successfully";
    Layout = "_CaptivePortalLayout";
}

<div class="success-page text-center">
    <div class="success-icon mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
    </div>
    
    <h1 class="success-title mb-3">Welcome to WTAMU Wi-Fi!</h1>
    <p class="success-message mb-4">You are now connected to our wireless network.</p>
    
    <div class="connection-info bg-light p-4 rounded mb-4">
        <h5>Connection Details</h5>
        <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
        <p class="mb-1"><strong>Connected at:</strong> @Model.ConnectedAt.ToString("MMM dd, yyyy h:mm tt")</p>
        <p class="mb-0"><strong>Location:</strong> @Model.Location</p>
    </div>
    
    <div class="helpful-links mb-4">
        <h5>Quick Links</h5>
        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
            <a href="https://wtamu.edu" class="btn btn-primary">WTAMU Homepage</a>
            <a href="https://buffalomail.wtamu.edu" class="btn btn-outline-primary">BuffaloMail</a>
            <a href="https://wtclass.wtamu.edu" class="btn btn-outline-primary">WTClass</a>
        </div>
    </div>
    
    <div class="session-info alert alert-info">
        <i class="bi bi-info-circle"></i>
        <strong>Session Information:</strong> Your connection will remain active for 24 hours. 
        After that, you may need to reconnect by visiting this page again.
    </div>
</div>